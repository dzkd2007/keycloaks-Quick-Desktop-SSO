# QuickSuite Desktop SSO — environment variables template
#
# 把本文件复制成 .env 后填值，所有脚本和命令都从 .env 取值。
# .env 已在 .gitignore 里，不要把它 commit。
#
#   cp .env.example .env
#   vim .env

# === AWS Account / Region ===
AWS_REGION=us-east-1
# 必须填账号 ID（部署中多处需要）
AWS_ACCOUNT_ID=

# === VPC & 子网 ===
# 已存在的 VPC（必须有 NAT 出公网，私有子网跨 ≥2 AZ，公有子网跨 ≥2 AZ）
VPC_ID=
# 私有子网，给 Aurora 用，必须在两个不同 AZ
PRIVATE_SUBNET_1=
PRIVATE_SUBNET_2=
# 公有子网（给 ALB 用），两个不同 AZ
PUBLIC_SUBNET_1=
PUBLIC_SUBNET_2=
# ECS Fargate 任务的子网（必须和 ALB 至少一个 AZ 重合，否则 target 会被标 unused）
# 通常等于 PRIVATE_SUBNET_1 或 PRIVATE_SUBNET_2 中和某个 PUBLIC_SUBNET 同 AZ 的那个
ECS_SUBNET=

# === Managed AD ===
AD_DOMAIN_NAME=corp.example.com
AD_SHORT_NAME=CORP
# 强密码：≥8 字符，含大小写 + 数字 + 符号
AD_ADMIN_PASSWORD=
AD_EDITION=Standard

# === Route53 / ACM ===
# 已存在的 Route53 hosted zone（公网解析）的 ID
ROUTE53_HOSTED_ZONE_ID=
# 公网域名（须在 Route53 hosted zone 内），用户 + Quick Desktop 都打这个域名
KEYCLOAK_DOMAIN=keycloak.example.com
# CloudFront 回源用的内部 alias（任选 *.<你的域>，不能与现有记录冲突）
ORIGIN_ALIAS_NAME=kc-origin.example.com
# ACM 证书 ARN，必须在 us-east-1 region，必须同时覆盖
# KEYCLOAK_DOMAIN 和 ORIGIN_ALIAS_NAME（最简单是用通配 *.example.com）
CERTIFICATE_ARN=

# === Keycloak ===
KEYCLOAK_ADMIN_USER=admin
# 强密码
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:25.0
KEYCLOAK_REALM=quicksuite
# OIDC public client 名（Quick 控制台填的 client ID）
KEYCLOAK_OIDC_CLIENT_ID=amazon-quick-desktop
# Keycloak SAML IdP alias（Keycloak ACS URL 路径里的标识；要与 IdC 那边的 ACS URL 一致）
KEYCLOAK_IDP_ALIAS=iam-identity-center

# === Aurora PostgreSQL ===
DB_MASTER_USERNAME=keycloak
# 强密码
DB_MASTER_PASSWORD=

# === ALB ingress prefix list ===
# CloudFront origin-facing managed prefix list（us-east-1 是 pl-3b927c52）
# 其它 region 见 https://docs.aws.amazon.com/AmazonCloudFront/latest/DeveloperGuide/LocationsOfEdgeServers.html
ALB_INGRESS_PREFIX_LIST_ID=pl-3b927c52

# === IAM Identity Center ===
# 通过 `aws sso-admin list-instances --region us-east-1` 查出
IDC_INSTANCE_ARN=
IDC_IDENTITY_STORE_ID=
# Step 4 完成后填
IDC_SAML_APPLICATION_ARN=
# Step 4 下载的 SAML metadata 文件名（放在仓库根）
IDC_SAML_METADATA_FILE=idc-saml-metadata.xml

# === Quick (Suite) ===
# 通过 `aws quicksight describe-account-subscription --aws-account-id $AWS_ACCOUNT_ID --region us-east-1` 查
QUICK_NAMESPACE=
# 应为 IAM_IDENTITY_CENTER（如果不是，本部署链路不适用，需先把 Quick 改成 IdC backed）
QUICK_AUTHENTICATION_TYPE=

# === 部署期临时变量（deploy-infra.sh 写回） ===
ALB_DNS_NAME=
ALB_HOSTED_ZONE_ID=
CLOUDFRONT_DOMAIN_NAME=
CLOUDFRONT_DISTRIBUTION_ID=
AD_DIRECTORY_ID=
AD_DNS_IP_1=
AD_DNS_IP_2=
