# QuickSuite Desktop SSO — environment variables template
#
# 把本文件复制成 .env 后填值，所有脚本和命令都从 .env 取值。
# .env 已在 .gitignore 里，不要把它 commit。
#
#   cp .env.example .env
#   vim .env

# === 场景选择 ===
# idc  = 场景 1: Quick 是 IAM Identity Center backed，Keycloak 桥接 OIDC↔SAML 给 IdC
# ad   = 场景 2: Quick 是 Active Directory backed，Keycloak 通过 LDAP federation 直连 AD
SCENARIO=idc

# === AWS Account / Region ===
AWS_REGION=us-east-1
# 必须填账号 ID（部署中多处需要）
AWS_ACCOUNT_ID=

# === VPC & 子网 ===
VPC_ID=
PRIVATE_SUBNET_1=
PRIVATE_SUBNET_2=
PUBLIC_SUBNET_1=
PUBLIC_SUBNET_2=
ECS_SUBNET=

# === Managed AD ===
# 场景 1：可选（部署 LDAP federation 给将来用）。不部署 AD 可省 ~$88/月。
# 场景 2：必需（Quick 的密码权威 + 用户来源）。
AD_DOMAIN_NAME=corp.example.com
AD_SHORT_NAME=CORP
AD_ADMIN_PASSWORD=
AD_EDITION=Standard

# === Route53 / ACM ===
ROUTE53_HOSTED_ZONE_ID=
KEYCLOAK_DOMAIN=keycloak.example.com
ORIGIN_ALIAS_NAME=kc-origin.example.com
CERTIFICATE_ARN=

# === Keycloak ===
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=
KEYCLOAK_IMAGE=quay.io/keycloak/keycloak:25.0
KEYCLOAK_REALM=quicksuite
KEYCLOAK_OIDC_CLIENT_ID=amazon-quick-desktop
# 场景 1 用这个 alias（也是 Keycloak ACS URL 路径里的标识）
KEYCLOAK_IDP_ALIAS=iam-identity-center

# === Aurora PostgreSQL ===
DB_MASTER_USERNAME=keycloak
DB_MASTER_PASSWORD=

# === ALB ingress prefix list ===
ALB_INGRESS_PREFIX_LIST_ID=pl-3b927c52

# === IAM Identity Center（场景 1 必需，场景 2 不用） ===
IDC_INSTANCE_ARN=
IDC_IDENTITY_STORE_ID=
IDC_SAML_APPLICATION_ARN=
IDC_SAML_METADATA_FILE=idc-saml-metadata.xml

# === AD 测试用户（场景 2 必需，由 ad-setup-quick.sh 用） ===
AD_TEST_USER_SAM=quicktest1
AD_TEST_USER_EMAIL=
AD_TEST_USER_PASSWORD=

# === Quick (Suite) ===
QUICK_AWS_ACCOUNT_ID=
# 场景 1: ACCOUNT_NAME 是创建 Quick 时填的；订阅必须先选 IdC
# 场景 2: ACCOUNT_NAME 是创建 Quick 时填的；订阅必须先选 Active Directory，绑定下面的 group
QUICK_NAMESPACE=
QUICK_AUTHENTICATION_TYPE=
# 场景 2 用：3 个 AD group，由 ad-setup-quick.sh 创建，订阅 Quick 时绑给 Admin/Author/Reader
QUICK_AD_GROUP_ADMIN=quickadmins
QUICK_AD_GROUP_AUTHOR=quickauthors
QUICK_AD_GROUP_READER=quickreaders

# === 部署期临时变量（deploy-infra.sh 写回） ===
ALB_DNS_NAME=
ALB_HOSTED_ZONE_ID=
CLOUDFRONT_DOMAIN_NAME=
CLOUDFRONT_DISTRIBUTION_ID=
AD_DIRECTORY_ID=
AD_DNS_IP_1=
AD_DNS_IP_2=
